    "ECRIEntry": {
      "additionalProperties": false,
      "description": "A single ECRI (Existing Customer Rent Increase) schedule entry.",
      "properties": {
        "month": {
          "description": "Month of tenancy when increase occurs",
          "minimum": 1,
          "title": "Month",
          "type": "integer"
        },
        "pct_increase": {
          "description": "Percentage increase [0,1]",
          "maximum": 1,
          "minimum": 0,
          "title": "Pct Increase",
          "type": "number"
        }
      },
      "required": [
        "month",
        "pct_increase"
      ],
      "title": "ECRIEntry",
      "type": "object"
    },
    "LeaseUpEntry": {
      "additionalProperties": false,
