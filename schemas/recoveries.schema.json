            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Base Year Start"
      },
      "cam_cap_annual_pct": {
        "anyOf": [
          {
            "maximum": 1,
            "minimum": 0,
            "type": "number"
          },
          {
            "type": "null"
          }
