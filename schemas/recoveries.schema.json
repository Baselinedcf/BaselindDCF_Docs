        "default": null,
        "title": "Base Annual Amount"
      },
      "base_per_uom": {
        "anyOf": [
          {
            "minimum": 0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Base Per Uom"
