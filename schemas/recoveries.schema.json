        "title": "Recovery Method Id",
        "type": "string"
      },
      "recovery_method_name": {
        "title": "Recovery Method Name",
        "type": "string"
      },
      "recovery_type": {
        "enum": [
          "no_recoveries",
          "net",
          "gross_over_base_year",
          "gross_over_base_year_amount",
          "gross_over_base_year_per_uom",
          "flat_amount",
          "flat_amount_per_uom",
          "combined"
