        "type": "string"
      },
      "flat_custom_inflation_rates": {
        "anyOf": [
          {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Flat Custom Inflation Rates"
      },
      "flat_inflation_ref": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
