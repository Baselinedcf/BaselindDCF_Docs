        "type": "string"
      },
      "components": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/RecoveryComponent"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Components"
      },
      "expense_group_config": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/ExpenseGroupRef"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Expense Group Config"
