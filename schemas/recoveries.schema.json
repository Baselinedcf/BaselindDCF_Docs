    "required": [
      "recovery_method_id",
      "recovery_method_name",
      "expenses_included",
      "grossup_occupancy",
      "recovery_type"
    ],
    "title": "RecoveryMethod",
    "type": "object"
  },
  "maxItems": 100,
  "title": "RecoveryMethodList",
  "type": "array"
}
