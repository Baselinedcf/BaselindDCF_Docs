      "flat_monthly_values": {
        "anyOf": [
          {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Flat Monthly Values"
      },
      "flat_yearly_values": {
        "anyOf": [
          {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Flat Yearly Values"
      },
      "grossup_occupancy": {
        "title": "Grossup Occupancy",
        "type": "boolean"
      },
      "grossup_occupancy_pct": {
        "anyOf": [
          {
            "maximum": 1,
            "minimum": 0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Grossup Occupancy Pct"
      },
      "max_tenant_recovery_amount": {
        "anyOf": [
          {
            "minimum": 0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Max Tenant Recovery Amount"
      },
      "max_tenant_recovery_per_uom": {
        "anyOf": [
          {
            "minimum": 0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Max Tenant Recovery Per Uom"
      },
      "min_tenant_recovery_amount": {
        "anyOf": [
          {
            "minimum": 0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Min Tenant Recovery Amount"
      },
      "min_tenant_recovery_per_uom": {
        "anyOf": [
          {
            "minimum": 0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Min Tenant Recovery Per Uom"
      },
      "pro_rata_alternate_area_ref": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Pro Rata Alternate Area Ref"
      },
      "pro_rata_area_source": {
        "anyOf": [
          {
            "enum": [
              "property_area",
              "alternate_area_ref"
            ],
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Pro Rata Area Source"
      },
      "pro_rata_method": {
        "anyOf": [
          {
            "enum": [
              "calc_on_area",
              "input_pct"
            ],
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Pro Rata Method"
      },
      "pro_rata_pct": {
        "anyOf": [
          {
            "maximum": 1,
            "minimum": 0,
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Pro Rata Pct"
      },
