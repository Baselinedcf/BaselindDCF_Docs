        "input_method": {
          "default": "amount",
          "enum": [
            "amount",
            "amount_per_area_unit",
            "detailed_amount",
            "detailed_per_area_unit",
            "por",
            "par",
            "detailed_por",
            "detailed_par",
            "pct_of_line",
            "pct_of_line_detailed"
          ],
          "title": "Input Method",
          "type": "string"
        },
        "is_property_tax": {
          "default": false,
          "title": "Is Property Tax",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "occupancy_type": {
