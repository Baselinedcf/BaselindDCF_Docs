{
  "$defs": {
    "CapitalReserve": {
      "additionalProperties": false,
      "description": "Capital reserve (FF&E reserve) — configurable basis.",
      "properties": {
        "basis": {
          "default": "total_revenue",
          "enum": [
            "total_revenue",
            "departmental_profit"
          ],
          "title": "Basis",
          "type": "string"
        },
        "pct_of_total_revenue": {
          "default": 0.04,
          "maximum": 1,
          "minimum": 0,
          "title": "Pct Of Total Revenue",
          "type": "number"
        }
      },
      "title": "CapitalReserve",
      "type": "object"
    },
    "CompSetHotel": {
      "additionalProperties": false,
      "description": "A competitive set hotel.",
      "properties": {
        "adr": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Adr"
        },
        "chain_scale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Chain Scale"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "occupancy": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Occupancy"
        },
        "rooms": {
          "minimum": 1,
          "title": "Rooms",
          "type": "integer"
        },
        "year_opened": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Year Opened"
        }
      },
      "required": [
        "name",
        "rooms"
      ],
      "title": "CompSetHotel",
      "type": "object"
    },
    "CostApproachInput": {
      "additionalProperties": false,
      "description": "Inputs for cost approach valuation.",
      "properties": {
        "base_construction_cost": {
          "minimum": 0,
          "title": "Base Construction Cost",
          "type": "number"
        },
        "entrepreneurial_profit_pct": {
          "default": 0.2,
          "maximum": 1,
          "minimum": 0,
          "title": "Entrepreneurial Profit Pct",
          "type": "number"
        },
        "external_obsolescence_pct": {
          "default": 0.0,
          "maximum": 1,
          "minimum": 0,
          "title": "External Obsolescence Pct",
          "type": "number"
        },
        "ffe": {
          "$ref": "#/$defs/FFEInput"
        },
        "functional_obsolescence_pct": {
          "default": 0.0,
          "maximum": 1,
          "minimum": 0,
          "title": "Functional Obsolescence Pct",
          "type": "number"
        },
        "indirect_cost_pct": {
          "default": 0.1,
          "maximum": 1,
          "minimum": 0,
          "title": "Indirect Cost Pct",
          "type": "number"
        },
        "lump_sums": {
          "default": 0.0,
          "minimum": 0,
          "title": "Lump Sums",
          "type": "number"
        },
        "physical_deterioration_pct": {
          "maximum": 1,
          "minimum": 0,
          "title": "Physical Deterioration Pct",
          "type": "number"
        },
        "site_value": {
          "minimum": 0,
          "title": "Site Value",
          "type": "number"
        }
      },
      "required": [
        "base_construction_cost",
        "physical_deterioration_pct",
        "site_value",
        "ffe"
      ],
      "title": "CostApproachInput",
      "type": "object"
    },
    "DirectCapInput": {
      "additionalProperties": false,
      "description": "Inputs for direct capitalization approach.",
      "properties": {
        "overall_cap_rate": {
          "exclusiveMinimum": 0,
          "maximum": 1,
          "title": "Overall Cap Rate",
          "type": "number"
        },
        "stabilized_year_index": {
          "minimum": 0,
          "title": "Stabilized Year Index",
          "type": "integer"
        }
      },
      "required": [
        "overall_cap_rate",
        "stabilized_year_index"
      ],
      "title": "DirectCapInput",
      "type": "object"
    },
    "FFEInput": {
      "additionalProperties": false,
      "description": "FF&E (Furniture, Fixtures & Equipment) valuation inputs.",
      "properties": {
        "cost_per_room": {
          "minimum": 0,
          "title": "Cost Per Room",
          "type": "number"
        },
        "economic_life": {
          "default": 10,
          "minimum": 1,
          "title": "Economic Life",
          "type": "integer"
        },
        "effective_age": {
          "minimum": 0,
          "title": "Effective Age",
          "type": "integer"
        }
      },
      "required": [
        "cost_per_room",
        "effective_age"
      ],
      "title": "FFEInput",
      "type": "object"
    },
    "HistoricalYear": {
      "additionalProperties": false,
      "description": "One year of historical operating data.",
      "properties": {
        "adr": {
          "minimum": 0,
          "title": "Adr",
          "type": "number"
        },
        "noi": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Noi"
        },
        "occupancy": {
          "maximum": 1,
          "minimum": 0,
          "title": "Occupancy",
          "type": "number"
        },
        "revpar": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revpar"
        },
        "total_revenue": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Revenue"
        },
        "year": {
          "title": "Year",
          "type": "integer"
        }
      },
      "required": [
        "year",
        "occupancy",
        "adr"
      ],
      "title": "HistoricalYear",
      "type": "object"
    },
    "HotelAssumptions": {
      "additionalProperties": false,
      "description": "Master assumption set driving the hotel DCF.",
      "properties": {
        "adr_by_year": {
          "items": {
            "type": "number"
          },
          "minItems": 1,
          "title": "Adr By Year",
          "type": "array"
        },
        "capital_reserve": {
          "$ref": "#/$defs/CapitalReserve"
        },
        "days_open": {
          "default": 365,
          "maximum": 366,
          "minimum": 1,
          "title": "Days Open",
          "type": "integer"
        },
        "departmental_expenses": {
          "items": {
            "$ref": "#/$defs/HotelExpenseItem"
          },
          "title": "Departmental Expenses",
          "type": "array"
        },
        "fixed_charges": {
          "items": {
            "$ref": "#/$defs/HotelFixedCharge"
          },
          "title": "Fixed Charges",
          "type": "array"
        },
        "inflation_rate": {
          "default": 0.03,
          "maximum": 1,
          "minimum": 0,
          "title": "Inflation Rate",
          "type": "number"
        },
        "management_fee": {
          "$ref": "#/$defs/ManagementFee"
        },
        "occupancy_by_year": {
          "items": {
            "type": "number"
          },
          "minItems": 1,
          "title": "Occupancy By Year",
          "type": "array"
        },
        "revenue_departments": {
          "items": {
            "$ref": "#/$defs/RevenueDepartment"
          },
          "title": "Revenue Departments",
          "type": "array"
        },
        "stabilization_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stabilization Year"
        },
        "undistributed_expenses": {
          "items": {
            "$ref": "#/$defs/HotelUndistributedExpense"
          },
          "title": "Undistributed Expenses",
          "type": "array"
        }
      },
      "required": [
        "occupancy_by_year",
        "adr_by_year"
      ],
      "title": "HotelAssumptions",
      "type": "object"
    },
    "HotelExpenseItem": {
      "additionalProperties": false,
      "description": "Expense line with fixed/variable split.",
      "properties": {
        "base_amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Base Amount"
        },
        "department": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Department"
        },
        "detailed_yearly_values": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detailed Yearly Values"
        },
        "driver": {
          "enum": [
            "occupied_rooms",
            "total_revenue",
            "room_revenue"
          ],
          "title": "Driver",
          "type": "string"
        },
        "fixed_pct": {
          "maximum": 1,
          "minimum": 0,
          "title": "Fixed Pct",
          "type": "number"
        },
        "inflation_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inflation Ref"
        },
        "input_method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Method"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "per_available_room": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Per Available Room"
        },
        "per_occupied_room": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Per Occupied Room"
        },
        "ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ratio"
        },
        "variable_pct": {
          "maximum": 1,
          "minimum": 0,
          "title": "Variable Pct",
          "type": "number"
        }
      },
      "required": [
        "name",
        "fixed_pct",
        "variable_pct",
        "driver"
      ],
      "title": "HotelExpenseItem",
      "type": "object"
    },
    "HotelFixedCharge": {
      "additionalProperties": false,
