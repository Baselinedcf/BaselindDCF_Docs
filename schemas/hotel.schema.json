          ],
          "default": null,
          "title": "Pct Line Refs"
        },
        "pct_recoverable": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Recoverable"
        },
        "variable_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Variable Pct"
        }
      },
      "required": [
        "name"
      ],
      "title": "HotelFixedCharge",
      "type": "object"
    },
    "HotelPctLineRef": {
      "additionalProperties": false,
