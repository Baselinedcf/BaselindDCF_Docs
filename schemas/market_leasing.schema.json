{
  "$defs": {
    "MLCAbatementMonthEntry": {
      "additionalProperties": false,
      "description": "A single month in a per-month abatement schedule for MLC.",
      "properties": {
        "abatement_pct": {
          "maximum": 1,
          "minimum": 0,
          "title": "Abatement Pct",
          "type": "number"
        },
        "lease_month": {
          "exclusiveMinimum": 0,
          "title": "Lease Month",
          "type": "integer"
        }
      },
      "required": [
        "lease_month",
        "abatement_pct"
      ],
      "title": "MLCAbatementMonthEntry",
      "type": "object"
    },
    "RentStepEntry": {
      "additionalProperties": false,
      "description": "A single rent step escalation entry.",
      "properties": {
        "increase_type": {
          "enum": [
            "pct_increase",
            "fixed_step"
          ],
          "title": "Increase Type",
          "type": "string"
        },
        "lease_month": {
          "exclusiveMinimum": 0,
          "title": "Lease Month",
          "type": "integer"
        },
        "value": {
          "minimum": 0,
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "lease_month",
        "increase_type",
        "value"
      ],
      "title": "RentStepEntry",
      "type": "object"
    }
  },
