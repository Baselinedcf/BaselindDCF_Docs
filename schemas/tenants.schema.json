{
  "$defs": {
    "AbatementMonthEntry": {
      "additionalProperties": false,
      "description": "A single month in a per-month abatement schedule.",
      "properties": {
        "abatement_pct": {
          "maximum": 1,
          "minimum": 0,
          "title": "Abatement Pct",
          "type": "number"
        },
        "lease_month": {
          "minimum": 1,
          "title": "Lease Month",
          "type": "integer"
        }
      },
      "required": [
        "lease_month",
        "abatement_pct"
      ],
      "title": "AbatementMonthEntry",
      "type": "object"
    },
    "AreaRemeasurementChange": {
      "additionalProperties": false,
      "description": "A scheduled change to a suite's rentable SF (area remeasurement).",
      "properties": {
        "at_renewal": {
          "default": true,
          "title": "At Renewal",
          "type": "boolean"
        },
        "effective_date": {
          "anyOf": [
            {
              "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective Date"
        },
        "new_sf": {
          "minimum": 0,
          "title": "New Sf",
          "type": "number"
        }
      },
      "required": [
        "new_sf"
      ],
      "title": "AreaRemeasurementChange",
      "type": "object"
    },
    "GrowthRateConfig": {
      "additionalProperties": false,
      "description": "Growth rate source configuration for rent annual increases.",
      "properties": {
        "growth_method_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Growth Method Ref"
        },
        "method": {
          "enum": [
            "select_growth_rate",
            "input_annual_pct"
          ],
          "title": "Method",
          "type": "string"
        },
        "rate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rate"
        }
      },
      "required": [
        "method"
      ],
      "title": "GrowthRateConfig",
      "type": "object"
    },
    "LcDetailedEntry": {
      "additionalProperties": false,
      "description": "A single LC disbursement at a specific lease month.",
      "properties": {
        "amount": {
          "minimum": 0,
          "title": "Amount",
          "type": "number"
        },
        "lease_month": {
          "maximum": 240,
          "minimum": 1,
          "title": "Lease Month",
          "type": "integer"
        }
      },
      "required": [
        "lease_month",
        "amount"
      ],
      "title": "LcDetailedEntry",
      "type": "object"
    },
    "PctRentTier": {
      "additionalProperties": false,
      "description": "A tier in tiered percentage rent.",
      "properties": {
        "pct": {
          "maximum": 1,
          "minimum": 0,
          "title": "Pct",
          "type": "number"
        },
        "sales_above": {
          "minimum": 0,
          "title": "Sales Above",
          "type": "number"
        }
      },
      "required": [
        "sales_above",
        "pct"
      ],
      "title": "PctRentTier",
      "type": "object"
    },
    "RentChangeEntry": {
      "additionalProperties": false,
      "description": "A single rent change in a changing_rent schedule.",
      "properties": {
        "change_type": {
          "enum": [
            "pct_increase",
            "amount",
            "amount_year",
            "amount_month",
            "amount_per_uom",
            "amount_per_uom_month",
            "dollar_increase"
          ],
          "title": "Change Type",
          "type": "string"
        },
        "day_of_month": {
          "default": 1,
          "maximum": 31,
          "minimum": 1,
          "title": "Day Of Month",
          "type": "integer"
        },
        "lease_month": {
          "minimum": 1,
          "title": "Lease Month",
          "type": "integer"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "lease_month",
        "change_type",
        "value"
      ],
      "title": "RentChangeEntry",
      "type": "object"
    },
    "Suite": {
      "additionalProperties": false,
      "description": "A single suite within a tenant's leased space.",
      "properties": {
        "area_remeasurement_changes": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/AreaRemeasurementChange"
              },
              "maxItems": 20,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Area Remeasurement Changes"
        },
        "current_sf": {
          "minimum": 0,
          "title": "Current Sf",
          "type": "number"
        },
        "floor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Floor"
        },
        "suite_id": {
          "title": "Suite Id",
          "type": "string"
        },
        "suite_name": {
          "title": "Suite Name",
          "type": "string"
        }
      },
      "required": [
        "suite_id",
        "suite_name",
        "current_sf"
      ],
      "title": "Suite",
      "type": "object"
    },
    "TiDetailedEntry": {
      "additionalProperties": false,
      "description": "A single TI disbursement at a specific lease month.",
      "properties": {
        "amount": {
          "minimum": 0,
          "title": "Amount",
          "type": "number"
        },
        "lease_month": {
          "maximum": 240,
          "minimum": 1,
          "title": "Lease Month",
          "type": "integer"
        }
      },
      "required": [
        "lease_month",
        "amount"
      ],
      "title": "TiDetailedEntry",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
